{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "changes.schema.json",
  "title": "Changes",
  "description": "Output produit par refactor-executor : changements appliqués, skips et validations génériques.",
  "type": "object",
  "required": ["generated_at", "applied", "skipped", "validation_results"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "applied": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "type", "description", "blast_radius_checked", "validated", "tools_passed"],
        "properties": {
          "file": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "blast_radius_checked": { "type": "boolean" },
          "validated": { "type": "boolean" },
          "tools_passed": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "reason"],
        "properties": {
          "file": { "type": "string" },
          "reason": { "type": "string" },
          "validation_output": { "type": "string" },
          "recommendation": { "type": "string" },
          "blast_radius": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "validation_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/validationResult" }
    }
  },
  "$defs": {
    "validationResult": {
      "type": "object",
      "required": ["name", "command", "status"],
      "properties": {
        "name": { "type": "string" },
        "command": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "skipped"]
        },
        "output_path": { "type": "string" },
        "summary": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
