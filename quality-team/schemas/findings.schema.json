{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "findings.schema.json",
  "title": "Findings",
  "description": "Output produit par scout : analyse statique consolidée et profil projet détecté.",
  "type": "object",
  "required": [
    "scope",
    "generated_at",
    "project",
    "tools_used",
    "validation_candidates",
    "hotspots",
    "dead_code",
    "complexity",
    "clones",
    "lint",
    "unused_deps",
    "errors"
  ],
  "properties": {
    "scope": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "object",
      "required": ["manifests", "languages", "frameworks", "playbooks_applicable", "validation_commands"],
      "properties": {
        "manifests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "frameworks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "playbooks_applicable": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation_commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/validationCommand" }
        }
      },
      "additionalProperties": false
    },
    "tools_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/validationCommand" }
    },
    "hotspots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "score", "reason"],
        "properties": {
          "file": { "type": "string" },
          "score": { "type": "number", "minimum": 0 },
          "reason": { "type": "string" },
          "blast_radius": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "dead_code": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "symbol", "type", "tool"],
        "properties": {
          "file": { "type": "string" },
          "symbol": { "type": "string" },
          "type": { "type": "string" },
          "tool": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "complexity": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "fn", "ccn", "nloc", "params", "threshold_breached"],
        "properties": {
          "file": { "type": "string" },
          "fn": { "type": "string" },
          "ccn": { "type": "integer", "minimum": 1 },
          "nloc": { "type": "integer", "minimum": 1 },
          "params": { "type": "integer", "minimum": 0 },
          "threshold_breached": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "clones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["files", "lines", "tool"],
        "properties": {
          "files": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2
          },
          "lines": { "type": "integer", "minimum": 1 },
          "tool": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "lint": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "rule", "severity", "message", "tool"],
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "rule": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["error", "warn", "info"]
          },
          "message": { "type": "string" },
          "tool": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "unused_deps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["package", "manager", "type", "tool"],
        "properties": {
          "package": { "type": "string" },
          "manager": { "type": "string" },
          "type": { "type": "string" },
          "tool": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "error"],
        "properties": {
          "tool": { "type": "string" },
          "error": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "validationCommand": {
      "type": "object",
      "required": ["name", "command", "reason"],
      "properties": {
        "name": { "type": "string" },
        "command": { "type": "string" },
        "reason": { "type": "string" },
        "applies_to": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
